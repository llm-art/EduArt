# Model Configuration
# Choose between "qwen" (local) or "gemini" (API)
MODEL_TYPE=gemini

# Google Gemini API Configuration (required if MODEL_TYPE=gemini)

# Optional: Custom Qwen model path (defaults to Qwen/Qwen2-VL-7B-Instruct)
QWEN_MODEL_PATH=Qwen/Qwen2-VL-7B-Instruct

# Optional: Gemini model name (defaults to gemini-2.0-flash-exp)
GEMINI_MODEL_NAME=gemini-2.5-flash-lite

# Processing Configuration
MAX_NEW_TOKENS=1024
TEMPERATURE=0.1


# ============================================================================
# LLM Evaluation Configuration (Script 4)
# ============================================================================

# LLM API Keys - Add your API keys here
GOOGLE_API_KEY=your_google_api_key_here
# OpenAI is accessed via Harvard API gateway using HARVARD_API_KEY (no separate key needed)
# OPENAI_API_KEY=your_openai_api_key_here  # Not needed — OpenAI uses HARVARD_API_KEY
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Harvard API Configuration
# Get your API key from: https://portal.apis.huit.harvard.edu/
HARVARD_API_KEY=your_harvard_api_key_here

# Harvard Bedrock API version: v1 or v2 (default: v2)
HARVARD_API_VERSION=v2

# Harvard OpenAI gateway tier: "community" (free $10/mo) or "paid" (HUIT billing)
# community = ais-openai-direct-limited-schools
# paid      = ais-openai-direct
HARVARD_OPENAI_TIER=community

# Optional: Specify which models to test (comma-separated)
# If not specified, all available models will be used based on API keys
# Examples:
#   openai/gpt-4o
#   google/gemini-2.5-flash-lite
#   anthropic/claude-3-5-sonnet-20241022
#   harvard/us.anthropic.claude-opus-4-5-20251101-v1:0
#   harvard/us.anthropic.claude-sonnet-4-5-20250929-v1:0
#   harvard/us.meta.llama3-3-70b-instruct-v1:0
MODELS_TO_TEST=

# LLM Processing Configuration
MAX_TOKENS=4096
TIMEOUT=30
