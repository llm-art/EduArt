# ============================================================================
# Question Preprocessing Configuration (Scripts 1-3)
# ============================================================================

# Model Configuration
# Choose between "qwen" (local) or "gemini" (API)
MODEL_TYPE=qwen

# Google Gemini API Configuration (required if MODEL_TYPE=gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Custom Qwen model path (defaults to Qwen/Qwen2-VL-7B-Instruct)
QWEN_MODEL_PATH=Qwen/Qwen2-VL-7B-Instruct

# Optional: Gemini model name (defaults to gemini-2.0-flash-exp)
GEMINI_MODEL_NAME=gemini-2.0-flash-exp

# Processing Configuration
MAX_NEW_TOKENS=512
TEMPERATURE=0.1

# ============================================================================
# LLM Evaluation Configuration (Script 4)
# ============================================================================

# LLM API Keys - Add your API keys here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Specify which models to test (comma-separated)
# If not specified, all available models will be used based on API keys
# Examples: openai/gpt-4o, google/gemini-2.5-flash-lite, anthropic/claude-3-5-sonnet-20241022
MODELS_TO_TEST=

# LLM Processing Configuration
MAX_TOKENS=512
TIMEOUT=30