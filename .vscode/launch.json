  "version": "0.2.0",
  "configurations": [
    {
      "name": "My_Zanichelli - Question downloader",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/questions/myzanichelli/1_question_downloader.py",
      "console": "integratedTerminal",
      "args": [
        "--exercise", "1",
        "--headless",
        //"--no-interaction"
      ]
    },
    {
      "name": "My_Zanichelli -  Question preprocessor",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/questions/myzanichelli/2_question_preprocessor.py",
      "console": "integratedTerminal",
      "args": [
        "-a",
        //"--exercise", "1",
        //"--max-question", "1"
        //"--force-ocr",
        "--verbose"
      ]
    },
    {
      "name": "AP_Art_History - 2010 Preprocessor ",
