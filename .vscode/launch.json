{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Question Downloader",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/questions/question_downloader.py",
      "console": "integratedTerminal",
      "args": ["--all"]
    },
    {
      "name": "[2] Question preprocessor",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/questions/2_question_preprocessor.py",
      "console": "integratedTerminal",
      "args": [
        "--exercise", "1",
        "--min-question", "1",
        "--max-question", "20",
        //"--force-ocr",
        "--verbose"
      ]
    },
    {
      "name": "[3] Question answerer",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/questions/3_question_answerer.py",
      "console": "integratedTerminal",
      "args": [
        "--exercises", "1",
        "--min-question", "1",
        "--max-question", "1",
        "-u", "https://esercizi.zanichelli.it/argomento/Pittura-rinascimentale/x2rnbu-x2rnih-hv05y",
        //"--headless"
      ]
    }
  ]
}