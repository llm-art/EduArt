{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Question Downloader",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/questions/question_downloader.py",
      "console": "integratedTerminal",
      "args": ["--all"]
    },
    {
      "name": "Python Debugger: Exam Question Processor",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/exam_question_processor.py",
      "console": "integratedTerminal",
      "args": [
        "--exercise", "4",
        "--min-question", "1",
        "--max-question", "2",
      ]
    }
  ]
}