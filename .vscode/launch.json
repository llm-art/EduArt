    {
      "name": " [FINAL] - [1] Dataset bundler",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/dataset_bundler.py",
      "console": "integratedTerminal",
      "args": [
        "--question-type", "completion_closed",
        "--question-type", "completion_open",
        "--question-type", "multiple_choice_check",
        "--question-type", "multiple_choice_radio",
        "--question-type", "positioning",
        "--question-type", "true_false",
        "--question-type", "select_errors",
