  "version": "0.2.0",
  "configurations": [
    {
      "name": "My_Zanichelli - Question downloader",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/questions/myzanichelli/1_question_downloader.py",
      "console": "integratedTerminal",
      "args": [
        "--exercise", "1",
        "--headless",
        //"--no-interaction"
      ]
    },
    {
      "name": "My_Zanichelli -  Question preprocessor",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/questions/myzanichelli/2_question_preprocessor.py",
      "console": "integratedTerminal",
      "args": [
        "--exercise", "1",
        //"--max-question", "1"
        //"--force-ocr",
        //"--verbose"
      ]
    },
    {
      "name": "My_Zanichelli - Dataset bundler",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/questions/myzanichelli/3_dataset_bundler.py",
      "console": "integratedTerminal",
      "args": []
    },
    {
      "name": "LLM Questioner",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/llm_questioner.py",
      "console": "integratedTerminal",
      "args": [
        "--start", "1",
        "--end", "5",
        // OpenAI models
        //"--models", "openai/gpt-4.1-2025-04-14",
        //"--models", "openai/gpt-5-2025-08-07",
        //"--models", "openai/o3-2025-04-16",

        // Google models
        //"--models", "google/gemini-2.5-pro",
        //"--models", "google/gemini-2.5-flash",
        "--models", "google/gemini-2.5-flash-lite",

        // Anthropic models
        //"--models", "anthropic/claude-haiku-4-5-20251001",
        //"--models", "anthropic/claude-sonnet-4-5-20250929",
        //"--models", "anthropic/claude-opus-4-1-20250805",

        //"--models", "anthropic/claude-3-5-sonnet-20241022",
        //"--models", "anthropic/claude-3-haiku-20240307",
        //"--models", "anthropic/claude-opus-4-20250514-thinking-16k",
        "--verbose",
        //"--question-mode", "text"
      ]
    }
  ]
}